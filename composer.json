{
	"name": "afspaces/asgaros-forum-spaces",
	"description": "Barrierearme Frontend-Verwaltung für Asgaros-Forenräume.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=8.1"
	},
	"require-dev": {
		"phpunit/phpunit": "^10.5"
	},
	"autoload": {
		"psr-4": {
			"AFSpaces\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"AFSpaces\\Tests\\": "tests/"
		}
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"scripts": {
		"test": "phpunit"
	}
}
